#!/usr/bin/env bash

set -euo pipefail

root="$(cd "$(dirname "${BASH_SOURCE[0]}")/../../.." && pwd)"
plugin_dir="$root/plugins/voxclaw"
manifest="$plugin_dir/.codex-plugin/plugin.json"
marketplace="$root/marketplace.json"
helper="$plugin_dir/scripts/voxclaw-say"
claude_marketplace="$root/.claude-plugin/marketplace.json"
claude_plugin_manifest="$plugin_dir/.claude-plugin/plugin.json"
claude_bin="$plugin_dir/bin/voxclaw-say"

require_file() {
  local path="$1"
  if [[ ! -f "$path" ]]; then
    echo "missing file: $path" >&2
    exit 1
  fi
}

require_file "$manifest"
require_file "$marketplace"
require_file "$claude_marketplace"
require_file "$claude_plugin_manifest"
require_file "$helper"
require_file "$claude_bin"

python3 - <<'PY' "$manifest" "$marketplace" "$claude_marketplace" "$claude_plugin_manifest"
import json
import sys

manifest_path, marketplace_path, claude_marketplace_path, claude_plugin_manifest_path = sys.argv[1:5]

with open(manifest_path, "r", encoding="utf-8") as f:
    manifest = json.load(f)

with open(marketplace_path, "r", encoding="utf-8") as f:
    marketplace = json.load(f)

with open(claude_marketplace_path, "r", encoding="utf-8") as f:
    claude_marketplace = json.load(f)

with open(claude_plugin_manifest_path, "r", encoding="utf-8") as f:
    claude_plugin_manifest = json.load(f)

assert manifest["name"] == "voxclaw"
assert manifest["version"] == "0.1.0"
assert manifest["interface"]["displayName"] == "VoxClaw"
assert manifest["skills"] == "./skills/"

plugins = marketplace["plugins"]
entry = next((p for p in plugins if p["name"] == "voxclaw"), None)
assert entry is not None
assert entry["source"]["path"] == "./plugins/voxclaw"
assert entry["policy"]["installation"] == "AVAILABLE"
assert entry["policy"]["authentication"] == "ON_INSTALL"

assert claude_marketplace["name"] == "malpern-marketplace"
claude_entry = next((p for p in claude_marketplace["plugins"] if p["name"] == "voxclaw"), None)
assert claude_entry is not None
assert claude_entry["version"] == "0.1.0"
assert claude_entry["source"] == "./plugins/voxclaw"
assert claude_entry["strict"] is True
assert claude_plugin_manifest["name"] == "voxclaw"
assert claude_plugin_manifest["homepage"] == "https://voxclaw.com/"

print("ok: codex and claude manifests")
PY

if command -v claude >/dev/null 2>&1; then
  claude plugin validate "$root" >/dev/null
  echo "ok: claude plugin validate"
fi

"$helper" --health
"$helper" "VoxClaw plugin smoke test successful."
